# ─────────────────────────────────────────────────────────────────────────────
# Royal Enterprises — Environment Variables
#
# USAGE:
#   cp .env.example .env.local
#   Fill in your values below.
#   .env.local is git-ignored and must NEVER be committed.
#
# Vite exposes all VITE_* vars to the client bundle at build time.
# Do NOT put truly secret server-side secrets here.
# ─────────────────────────────────────────────────────────────────────────────

# ── Contact Form ──────────────────────────────────────────────────────────────
# Formspree form ID (e.g. "xpwzbkla").
# If absent, the contact form falls back to WhatsApp redirect — zero enquiries lost.
# Get your ID at https://formspree.io/
VITE_FORMSPREE_ID=

# ── Analytics Dashboard ───────────────────────────────────────────────────────
# Secret key that gates the /analytics?key=<value> dashboard.
# REQUIRED — leave unset to disable dashboard access entirely.
# Change this to a long random string before deploying to production.
# Generate one: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
VITE_ANALYTICS_KEY=

# ── Google Analytics 4 ────────────────────────────────────────────────────────
# GA4 Measurement ID (e.g. "G-XXXXXXXXXX").
# Leave unset to disable GA4 entirely — no tracking scripts will be injected.
# Get your ID at https://analytics.google.com/
VITE_GA4_ID=

# ── Deployment ────────────────────────────────────────────────────────────────
# Base path for assets (e.g. "/" for root, or "/subdir/" for subdirectory deploys).
# Used by Vite for asset URLs. Defaults to "/" if not set.
# Examples: "/" (root), "/app/" (subdirectory), "https://cdn.example.com/" (CDN)
VITE_BASE_PATH=/
